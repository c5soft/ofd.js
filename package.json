{
  "name": "@ycsx/ofdjs",
  "version": "1.0.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "A Javascript class for reading and rendering ofd files",
  "main": "dist/ofd.min.js",
  "types": "index.d.ts",
  "files": [
    "dist/",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ index.js",
    "lint:fix": "eslint src/ index.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"index.js\"",
    "build": "webpack --config webpack.config.cjs",
    "build:dev": "webpack --config webpack.config.cjs --mode development",
    "dev": "vite",
    "dev:build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "author": "DLTech21 (original), Ycsx (modifications)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ycsx/ofd.js/",
    "directory": "."
  },
  "keywords": [
    "ofd",
    "document",
    "parser",
    "render",
    "viewer",
    "javascript",
    "ofd-format",
    "pdf-alternative"
  ],
  "dependencies": {
    "@lapo/asn1js": "2.1.3",
    "@sharp9/ofdjs": "0.1.0",
    "@xmldom/xmldom": "0.9.10",
    "js-md5": "0.8.3",
    "js-sha1": "0.7.0",
    "jsrsasign": "11.1.3",
    "jszip": "3.10.1",
    "jszip-utils": "0.1.0",
    "core-js": "3.49.0",
    "ofd-xml-parser": "0.0.6",
    "sm-crypto": "0.4.0",
    "web-streams-polyfill": "4.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.1",
    "webpack": "^5.108.0",
    "webpack-cli": "^7.0.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "Chrome > 50",
    "Firefox > 45",
    "Safari > 10",
    "Edge > 15"
  ]
}