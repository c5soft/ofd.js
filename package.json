{
  "name": "ofdts",
  "version": "1.0.0",
  "description": "A Typescript class for reading and rendering OFD files",
  "main": "dist/ofd.min.js",
  "module": "dist/ofd.js",
  "types": "dist/ofd.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "browser": "./dist/ofd.min.js",
      "module": "./dist/ofd.js",
      "import": "./dist/ofd.js",
      "default": "./dist/ofd.min.js"
    }
  },
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "build": "bun run scripts/build_dist.ts --minify",
    "build:dev": "bun run scripts/build_dist.ts",
    "dev": "vite",
    "dev:build": "vite build",
    "prepublishOnly": "bun run build"
  },
  "author": "DLTech21 (original), Ycsx (modifications)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ycsx/ofd.js/",
    "directory": "."
  },
  "keywords": [
    "ofd",
    "document",
    "parser",
    "render",
    "viewer",
    "javascript",
    "ofd-format",
    "pdf-alternative"
  ],
  "dependencies": {
    "core-js": "3.49.0",
    "jszip": "3.10.1",
    "fast-xml-parser": "^5.9.3",
    "sm-crypto": "0.4.0",
    "web-streams-polyfill": "4.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "vite": "^8.1.3"
  },
  "browserslist": [
    "Chrome > 50",
    "Firefox > 45",
    "Safari > 10",
    "Edge > 15"
  ]
}