{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": false,
    "declarationMap": false
  },
  "include": [
    "src/ofd/ofd.ts",
    "src/**/*.ts"
  ]
}
